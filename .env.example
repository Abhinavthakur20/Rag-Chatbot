GROK_API_KEY=your_key_here
# Optional provider override: xai | groq
# GROK_PROVIDER=xai
GROK_MODEL=grok-3-mini

# Supabase (recommended server-side variable names)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_or_publishable_key

# Alternate names accepted by this app (if already configured in hosting)
# NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_or_publishable_key
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your_supabase_anon_or_publishable_key

# Optional API base URL override:
# xAI default: https://api.x.ai/v1
# Groq default: https://api.groq.com/openai/v1
# GROK_API_BASE_URL=https://api.x.ai/v1
